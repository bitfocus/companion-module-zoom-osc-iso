{
	"name": "zoom-osc-iso",
	"version": "5.0.0",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "run build && companion-module-build",
		"build": "rimraf dist && run build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"test": "NODE_OPTIONS=--experimental-vm-modules jest",
		"lint:raw": "eslint",
		"lint": "run lint:raw .",
		"prettier": "prettier --write"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-zoom-osc-iso.git"
	},
	"engines": {
		"node": "^22.20",
		"yarn": "^4"
	},
	"dependencies": {
		"@companion-module/base": "2.0.4",
		"@fast-csv/parse": "^5.0.5",
		"got-cjs": "^12.5.4",
		"node-osc": "^11.4.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^3.0.1",
		"@jest/globals": "^30.2.0",
		"@types/got": "^9.6.12",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.19.17",
		"@types/node-osc": "^10.0.0",
		"eslint": "^9.39.4",
		"husky": "^9.1.7",
		"jest": "^30.2.0",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.59.0"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"./*.{css,json,md,scss}": [
			"prettier --write"
		],
		"!(.squad)/**/*.{css,json,md,scss}": [
			"prettier --write"
		],
		"./*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		],
		"!(.squad)/**/*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.12.0"
}
